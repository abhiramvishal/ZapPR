# API base URL — required for all environments
# Production: your deployed API (e.g. https://api.your-domain.com)
# Local dev: use your machine's LAN IP so the phone can reach the backend
#   Mac: run `ipconfig getifaddr en0`
#   Windows: run `ipconfig` and use IPv4 Address
EXPO_PUBLIC_API_URL=https://your-api-domain.com
